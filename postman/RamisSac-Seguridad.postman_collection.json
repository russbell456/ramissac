{
  "info": {
    "_postman_id": "ramissac-seguridad",
    "name": "RamisSac API — Pruebas de seguridad",
    "description": "Casos de seguridad: autenticación, autorización y acceso.\n\nUsuario seed: admin@example.com / admin123\n\nEjecutar carpeta completa con Collection Runner (orden secuencial).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "tokenAdmin", "value": "" },
    { "key": "tokenUser", "value": "" }
  ],
  "item": [
    {
      "name": "SEC-001 Sin token",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/auth/trabajadores"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('SEC-001: 401 sin token', () => pm.response.to.have.status(401));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "SEC-002 Token inválido",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer token.falso.invalido" }],
        "url": "{{baseUrl}}/auth/trabajadores"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('SEC-002: 401 token inválido', () => pm.response.to.have.status(401));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "SEC-003 Login incorrecto",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"wrongpass123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('SEC-003: 401 credenciales incorrectas', () => pm.response.to.have.status(401));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "Login Admin (setup)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Login admin 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('tokenAdmin', pm.response.json().access_token);"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "SEC-004 Trabajadores requiere rol almacenero/admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Usuario\",\n  \"apellidos\": \"Test\",\n  \"dni\": \"99887766\",\n  \"email\": \"user.sec004@test.com\",\n  \"password\": \"12345678\",\n  \"role\": \"user\"\n}"
        },
        "url": "{{baseUrl}}/auth/register"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('SEC-004 setup: registro user 201', () => pm.response.to.have.status(201));"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "SEC-004b Login user y acceso denegado",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user.sec004@test.com\",\n  \"password\": \"12345678\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Login user 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('tokenUser', pm.response.json().access_token);"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "SEC-004c User sin acceso a trabajadores",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{tokenUser}}" }],
        "url": "{{baseUrl}}/auth/trabajadores"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('SEC-004: 403 user sin permiso', () => pm.response.to.have.status(403));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "SEC-005 Admin accede a trabajadores",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
        "url": "{{baseUrl}}/auth/trabajadores"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('SEC-005: 200 admin autorizado', () => pm.response.to.have.status(200));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "SEC-006 Préstamo sin token",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"trabajador_id\": 1,\n  \"codigo_unico\": \"X\",\n  \"dni\": \"12345678\",\n  \"nombres_completos\": \"Test\",\n  \"cargo\": \"Op\",\n  \"fecha_prestamo\": \"2030-06-15T10:00:00\",\n  \"fecha_devolucion_prevista\": \"2030-06-20T10:00:00\",\n  \"items\": [{ \"articulo_id\": 1, \"cantidad\": 1 }],\n  \"firma_base64\": \"abc\"\n}"
        },
        "url": "{{baseUrl}}/almacen/registrar-prestamo-qr"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('SEC-006: 401 préstamo sin token', () => pm.response.to.have.status(401));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "SEC-007 SQL injection login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"' OR '1'='1\",\n  \"password\": \"admin123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('SEC-007: no bypass login', () => pm.expect(pm.response.code).to.be.oneOf([400, 401]));"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "SEC-008 Root público",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('SEC-008: root 200', () => pm.response.to.have.status(200));"],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "SEC-009 Catálogo artículos público",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/articulo/articulos"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('SEC-009: catálogo 200', () => pm.response.to.have.status(200));"],
          "type": "text/javascript"
        }
      }]
    }
  ]
}
