    {
      "name": "Login Admin (setup)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Login admin 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.collectionVariables.set('tokenAdmin', j.access_token);",
            "pm.collectionVariables.set('adminUserId', String(j.user.id));"
          ],
          "type": "text/javascript"
        }
      }]
    },
    {
      "name": "VAL-010 Actualizar usuario DNI inválido",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Admin\",\n  \"apellidos\": \"Principal\",\n  \"dni\": \"1234567A\",\n  \"email\": \"admin@example.com\"\n}"
        },
